# ── Provider API keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Optional — only needed when swapping the labor model via the UI toggle
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# ── Access control ───────────────────────────────────────────────────────────
# Invite code testers must enter (sent as x-access-code). Blank = open (dev).
ACCESS_CODE=
# Must match the Python service's PIPELINE_INTERNAL_SECRET in production.
PIPELINE_INTERNAL_SECRET=

# ── Supabase research logging (server-side; service key is never sent to the
#    browser). Blank = logging disabled, app still works. ─────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Browser client (later phases) — anon key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Python service URL (defaults to http://localhost:8000; unset on Vercel,
#    where the same-origin /api/py/* function is used) ────────────────────────
PYTHON_SERVICE_URL=http://localhost:8000
