# ── Provider API keys ───────────────────────────────────────────────────────
# At minimum, set both keys for the default config (Mistral orchestrator + Claude executor).
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# Optional — only needed when swapping the labor model via the UI toggle
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# ── Provider routing (which provider handles each pipeline role) ─────────────
# Values: claude | mistral | openai | gemini | xai
ORCHESTRATOR_PROVIDER=mistral
EXECUTOR_PROVIDER=claude
COMPYLER_PROVIDER=mistral

# ── Optional model overrides (leave blank to use adapter defaults) ────────────
# CLAUDE_MODEL=claude-opus-4-5
# MISTRAL_MODEL=open-mistral-7b
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-1.5-pro
# XAI_MODEL=grok-beta

# ── Service config ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
